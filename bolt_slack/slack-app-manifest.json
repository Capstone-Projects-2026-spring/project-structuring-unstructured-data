{
    "display_information": {
        "name": "SUD Bud",
        "description": "Assistant for the SUDS dashboarding service.",
        "background_color": "#0943b0"
    },
    "features": {
        "bot_user": {
            "display_name": "SUD Bud",
            "always_online": false
        },
        "slash_commands": [
            {
                "command": "/store-messages",
                "description": "Store entire message history from this channel.",
                "should_escape": false
            },
            {
                "command": "/messages",
                "description": "Retrieve recent messages from this channel.",
                "should_escape": false
            },
            {
                "command": "/channel-info",
                "description": "Display data about this channel.",
                "should_escape": false
            },
            {
                "command": "/store-members",
                "description": "Store data on all channel members.",
                "should_escape": false
            },
            {
                "command": "/members-info",
                "description": "Displays information about all members in the channel.",
                "should_escape": false
            },
            {
                "command": "/refresh-home",
                "description": "Refresh the SUD dashboard in the app home.",
                "should_escape": false
            },
            {
                "command": "/summary",
                "description": "This creates a summary of messages from the current week and past week",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "redirect_urls": [
            "https://project-structuring-unstructured-data-wc26.onrender.com/slack/oauth_redirect"
        ],
        "scopes": {
            "bot": [
                "reactions:write",
                "app_mentions:read",
                "channels:history",
                "channels:read",
                "chat:write",
                "commands",
                "im:history",
                "im:read",
                "im:write",
                "reactions:read",
                "users:read",
                "groups:read",
                "mpim:read",
                "metadata:read"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "request_url": "https://project-structuring-unstructured-data-wc26.onrender.com/slack/events",
            "bot_events": [
                "app_mention",
                "member_joined_channel",
                "message.channels",
                "message.im",
                "reaction_added"
            ]
        },
        "interactivity": {
            "is_enabled": true,
            "request_url": "https://project-structuring-unstructured-data-wc26.onrender.com/slack/events"
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "token_rotation_enabled": false
    }
}