{
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "mongoose": "^8.3.4",
    "python-shell": "^5.0.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "build": "npm install",
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:unit": "jest messages.route.test.js",
    "test:integration": "jest messages.integration.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
