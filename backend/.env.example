# .env.example — copy to .env and fill in your values

# Supabase PostgreSQL connection string
# Found in: Supabase dashboard → Project Settings → Database → Connection string → URI
# Use the "Session pooler" URI (port 5432), not the direct connection
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase project URL and service role key
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# JWT signing secret — set to any long random string in production
SECRET_KEY=change-me-in-production

# Set to True to enable the /auth/dev-login endpoint (local development only)
DEBUG=True

# OpenAI API key for AI suggestions
OPENAI_API_KEY=

# Self-hosted Judge0 CE (recommended for local development)
JUDGE0_URL=http://localhost:2358

# Optional if your Judge0 instance has authentication enabled
#JUDGE0_AUTH_TOKEN=
