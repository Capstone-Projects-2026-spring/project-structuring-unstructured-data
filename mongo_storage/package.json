{
  "dependencies": {
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.3.4",
    "python-shell": "^5.0.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "test": "jest",
    "test:unit": "jest messages.route.test.js",
    "test:integration": "jest messages.integration.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:setup": "node scripts/setup-local-db.js",
    "db:setup:docker": "node scripts/setup-local-db.js docker",
    "db:setup:local": "node scripts/setup-local-db.js local",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:logs": "docker compose logs -f mongodb"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
