# Slack Bot Configuration
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=signing_secret_here
SLACK_BOT_USER_ID=app_user_id_here
SLACK_APP_TOKEN=xapp-1-...
