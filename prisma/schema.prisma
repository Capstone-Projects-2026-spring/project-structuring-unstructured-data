// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js" // use js client instead of edge client recomended by docs
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  players       TeamPlayer[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model InfraTestKv {
  id  BigInt @id
  val String

  @@map("infra_test_kv")
}

model Party {
  id      String        @id @default(uuid())
  members PartyMember[]
}

model PartyMember {
  id      String @id @default(uuid())
  userId  String
  partyId String
  lobby   Party  @relation(fields: [partyId], references: [id])
}

enum GameStatus {
  WAITING
  STARTING
  ACTIVE
  FLIPPING
  FINISHED
  CANCELLED
}

enum GameType {
  TWOPLAYER
  FOURPLAYER
}

model GameRoom {
  id         String      @id @default(uuid())
  status     GameStatus  @default(STARTING)
  createdAt  DateTime    @default(now()) @map("created_at")
  endedAt    DateTime?
  problemId  String
  gameType   GameType
  problem    Problem     @relation(fields: [problemId], references: [id])
  teams      Team[]
  gameResult GameResult?

  @@index([problemId])
  @@map("game_rooms")
}

model Team {
  id         String       @id @default(uuid())
  gameRoomId String
  createdAt  DateTime     @default(now())
  gameRoom   GameRoom     @relation(fields: [gameRoomId], references: [id], onDelete: Cascade)
  players    TeamPlayer[]
  wonGame    GameResult?  @relation("WinningTeamRelation")

  @@index([gameRoomId])
}

enum Role {
  CODER
  TESTER
  SPECTATOR
}

model TeamPlayer {
  teamId      String
  userId      String
  role        Role
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum ProblemDifficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id               String            @id @default(uuid())
  title            String
  slug             String
  description      String
  topics           String[]
  difficulty       ProblemDifficulty
  successRate      Float
  totalSubmissions Int
  totalAccepted    Int
  likes            Int
  dislikes         Int
  starterCode      String?
  hints            String?

  gameRooms GameRoom[]
  tests     ProblemTest[]

  @@unique([slug])
  @@index([title])
  @@index([slug])
  @@map("problem")
}

model ProblemTest {
  id             String @id @default(uuid())
  problemId      String
  functionInput  Json // Strongly typed in the frontend
  expectedOutput Json // ^^
  language       String
  optimalTimeMs  Int

  problem Problem @relation(fields: [problemId], references: [slug], onDelete: Cascade)
}

model GameResult {
  id            String @id @default(uuid())
  gameRoomId    String @unique
  winningTeamId String? @unique
  team1Code      String?
  team2Code      String?
  team1TimeToPassMs Int?
  team2TimeToPassMs Int?

  winningTeam Team?     @relation("WinningTeamRelation", fields: [winningTeamId], references: [id])
  gameRoom    GameRoom @relation(fields: [gameRoomId], references: [id], onDelete: Cascade)

  @@index([winningTeamId])
}
